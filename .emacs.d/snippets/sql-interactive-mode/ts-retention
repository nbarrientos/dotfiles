# -*- mode: snippet -*-
# name: TimescaleDB: retention jobs
# key: ts-retention
# --
SELECT j.hypertable_name, j.hypertable_schema,
       j.job_id,
       config,
       schedule_interval,
       job_status,
       last_run_status,
       last_run_started_at,
       js.next_start,
       total_runs,
       total_successes,
       total_failures
  FROM timescaledb_information.jobs j
  JOIN timescaledb_information.job_stats js
    ON j.job_id = js.job_id
  WHERE j.proc_name = 'policy_retention';